{
  "name": "verko",
  "version": "0.3.7",
  "description": "Agent-first paper management. CSV + Markdown native storage.",
  "author": {
    "name": "CatVinci-Studio",
    "email": "leonardoshen@icloud.com"
  },
  "homepage": "https://github.com/CatVinci-Studio/Verko",
  "main": "./out/main/index.js",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite src/renderer --config vite.renderer.config.ts",
    "build:web": "vite build --config vite.renderer.config.ts",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
