{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Verko",
  "version": "0.5.0-dev.1",
  "identifier": "studio.catvinci.verko",
  "build": {
    "frontendDist": "../dist-tauri",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run tauri:dev:vite",
    "beforeBuildCommand": "npm run tauri:build:vite"
  },
  "app": {
    "windows": [
      {
        "title": "Verko",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "nsis",
      "deb",
      "appimage",
      "rpm"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      },
      "wix": {
        "language": "en-US"
      }
    }
  }
}
